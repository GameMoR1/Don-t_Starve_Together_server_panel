# Copy to .env on the server (install.sh creates this automatically).
# Never commit .env — it contains secrets.

PANEL_HOST=0.0.0.0
PANEL_PORT=8000
# PANEL_DEFAULT_PASSWORD= — если пуст, генерируется случайный при создании admin
# PANEL_SECRET_KEY — сгенерируйте: openssl rand -hex 32
# PANEL_SECRET_KEY=
DST_DIR=/home/dstpanel/dst
DATABASE_PATH=/var/lib/dst-panel/data.db
DST_PANEL_DB=/var/lib/dst-panel/data.db
STEAM_WEB_API_KEY=
